# Backend environment variables example
# Copy this to a file named .env and fill the values before running in production

# MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/flatmate-finder?retryWrites=true&w=majority

# JSON Web Token secret
JWT_SECRET=replace_this_with_a_strong_random_secret

# Node environment (development | production)
NODE_ENV=development

# Port your server should listen on
PORT=5000

# Generative AI integration (Hugging Face)
GENERATIVE_AI_PROVIDER=huggingface
GENERATIVE_AI_API_KEY=hf_xxx_your_token_here
